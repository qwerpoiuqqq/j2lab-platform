# ============================================================
# Quantum Campaign Automation - 환경 변수
# ============================================================
# 이 파일을 .env로 복사하여 사용하세요:
#   cp .env.example .env

# ---- App ----
SECRET_KEY=change-this-secret-key
DEBUG=false

# ---- Database ----
DATABASE_URL=sqlite:///./data/quantum.db

# ---- CORS (쉼표 구분, 비워두면 기본값 사용) ----
# 예시: CORS_ORIGINS=https://your-domain.com,https://xxxx.trycloudflare.com
CORS_ORIGINS=

# ---- 포트 설정 ----
FRONTEND_PORT=3000

# ---- Cloudflare Tunnel (Named Tunnel 사용 시) ----
# Cloudflare Zero Trust 대시보드에서 토큰 발급
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
