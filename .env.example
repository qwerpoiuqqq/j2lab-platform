# =============================================================================
# LOGIC LAB Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the actual values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to git!
# =============================================================================

# === Database (PostgreSQL) ===
DB_NAME=j2lab_platform
DB_USER=j2lab
DB_PASSWORD=change_me_to_secure_password
DB_HOST=db
# Local development without Docker: DB_HOST=localhost

# === API Server ===
SECRET_KEY=change_me_to_random_secret_key_at_least_32_chars
AES_ENCRYPTION_KEY=change_me_to_random_secret_key_at_least_32_chars
INTERNAL_API_SECRET=change_me_to_internal_secret_at_least_32_chars
SETTLEMENT_SECRET_PASSWORD=change_me_to_settlement_secret
DEBUG=false
# CORS: comma-separated origins
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173,https://logic-lab.kr,https://www.logic-lab.kr

# === JWT ===
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7

# === Keyword Worker (Decodo proxy for web scraping) ===
DECODO_USERNAME=your_decodo_username
DECODO_PASSWORD=your_decodo_password
DECODO_ENDPOINT_COUNT=500
# DECODO_HOST=gate.decodo.com
# DECODO_PORT=10001

# === Keyword Worker (Gemini AI for keyword classification) ===
GEMINI_API_KEY=your_gemini_api_key

# === Campaign Worker ===
# Keep DRY_RUN=true until you are ready for real superap submissions.
DRY_RUN=true

# === Internal Service URLs (Docker networking, do not change) ===
KEYWORD_WORKER_URL=http://keyword-worker:8001
CAMPAIGN_WORKER_URL=http://campaign-worker:8002
API_SERVER_URL=http://api-server:8000

# === Nginx Ports (change if 80/443 are already in use) ===
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# === Seed Data (used by scripts/seed-data.sh) ===
ADMIN_EMAIL=admin@j2lab.com
ADMIN_PASSWORD=admin123!
ADMIN_NAME=시스템관리자
